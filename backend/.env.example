# Server
PORT=5000

# CORS — comma-separated list of extra allowed origins (optional)
ALLOWED_ORIGINS=https://portfolio2026-lime.vercel.app,https://your-custom-domain.com

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=AdityaPortfolioDB
MONGO_DB_NAME_AI=AdityaPortfolioDBAI

# Authentication
JWT_SECRET=your_jwt_secret_here
ADMIN_RECOVERY_EMAIL=your_admin_recovery_email@example.com

# GitHub (for fetching repo data)
GITHUB_TOKEN=your_github_token_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
